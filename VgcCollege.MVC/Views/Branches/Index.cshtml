@model IEnumerable<VgcCollege.Domain.Branch>
@{ ViewData["Title"] = "Branches"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Branches</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Branch</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Name</th><th>Address</th><th>Courses</th><th></th></tr></thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@b.Id">@b.Name</a></td>
                        <td>@b.Address</td>
                        <td><span class="badge bg-secondary">@b.Courses.Count</span></td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@b.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@model VgcCollege.Domain.CourseEnrolment
@{ ViewData["Title"] = "Delete Enrolment"; }
<h2>Delete Enrolment</h2>
<div class="card p-4" style="max-width:500px">
    <div class="alert alert-danger">Remove enrolment for <strong>@Model.StudentProfile.Name</strong> from <strong>@Model.Course.Name</strong>?</div>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2"><button type="submit" class="btn btn-danger">Remove</button><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></div>
    </form>
</div>

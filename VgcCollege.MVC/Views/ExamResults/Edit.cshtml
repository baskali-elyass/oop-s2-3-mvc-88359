@model VgcCollege.Domain.ExamResult
@{ ViewData["Title"] = "Edit Exam Result"; }
<h2>Edit Exam Result</h2>
<p class="text-muted">@Model.Exam.Title — @Model.StudentProfile.Name</p>
<div class="card p-4" style="max-width:500px">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <input asp-for="Id" type="hidden" />
        <input asp-for="ExamId" type="hidden" />
        <input asp-for="StudentProfileId" type="hidden" />
        <div class="mb-3"><label asp-for="Score" class="form-label"></label><input asp-for="Score" class="form-control" type="number" step="0.5" /><span asp-validation-for="Score" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="Grade" class="form-label">Grade</label><input asp-for="Grade" class="form-control" maxlength="10" /></div>
        <div class="d-flex gap-2"><button type="submit" class="btn btn-primary">Save</button><a asp-action="Index" asp-route-examId="@Model.ExamId" class="btn btn-outline-secondary">Cancel</a></div>
    </form>
</div>

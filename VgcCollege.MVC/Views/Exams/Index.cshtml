@model IEnumerable<VgcCollege.Domain.Exam>
@{ ViewData["Title"] = "Exams"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Exams</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Exam</a>
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4"><select name="courseId" asp-items="ViewBag.Courses" class="form-select"><option value="">All Courses</option></select></div>
    <div class="col-auto"><button type="submit" class="btn btn-outline-secondary">Filter</button></div>
</form>
<div class="card"><div class="card-body p-0">
    <table class="table table-hover mb-0">
        <thead class="table-light"><tr><th>Title</th><th>Course</th><th>Date</th><th>Max</th><th>Status</th><th></th></tr></thead>
        <tbody>
            @foreach (var e in Model)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@e.Id">@e.Title</a></td>
                    <td><a asp-controller="Courses" asp-action="Details" asp-route-id="@e.CourseId">@e.Course.Name</a></td>
                    <td>@e.Date.ToShortDateString()</td>
                    <td>@e.MaxScore</td>
                    <td>
                        @if (e.ResultsReleased) { <span class="badge bg-success">Released</span> }
                        else { <span class="badge bg-warning text-dark">Provisional</span> }
                    </td>
                    <td class="text-end">
                        <a asp-controller="ExamResults" asp-action="Index" asp-route-examId="@e.Id" class="btn btn-sm btn-outline-info">Results</a>
                        @if (!e.ResultsReleased && User.IsInRole("Admin"))
                        {
                            <form asp-action="ReleaseResults" asp-route-id="@e.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-success ms-1">Release</button>
                            </form>
                        }
                        <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary ms-1">Edit</a>
                        <a asp-action="Delete" asp-route-id="@e.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div></div>

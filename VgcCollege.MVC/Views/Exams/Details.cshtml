@model VgcCollege.Domain.Exam
@{ ViewData["Title"] = Model.Title; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Title</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>
<div class="card p-3 mb-3">
    <div class="row">
        <div class="col-md-6">
            <p class="mb-1"><strong>Course:</strong> <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId">@Model.Course.Name</a></p>
            <p class="mb-1"><strong>Date:</strong> @Model.Date.ToShortDateString()</p>
            <p class="mb-0"><strong>Max Score:</strong> @Model.MaxScore</p>
        </div>
        <div class="col-md-6 d-flex align-items-center justify-content-end gap-2">
            @if (Model.ResultsReleased)
            { <span class="badge bg-success fs-6">Results Released</span> }
            else
            {
                <span class="badge bg-warning text-dark fs-6">Provisional</span>
                @if (User.IsInRole("Admin"))
                {
                    <form asp-action="ReleaseResults" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-success">Release Results Now</button>
                    </form>
                }
            }
        </div>
    </div>
</div>
<div class="d-flex justify-content-between align-items-center mb-2">
    <h5>Results (@Model.Results.Count)</h5>
    <a asp-controller="ExamResults" asp-action="Create" asp-route-examId="@Model.Id" class="btn btn-sm btn-primary">+ Add Result</a>
</div>
@if (!Model.Results.Any())
{ <div class="alert alert-info">No results entered yet.</div> }
else
{
    <div class="card"><div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Student</th><th>Score</th><th>%</th><th>Grade</th><th></th></tr></thead>
            <tbody>
                @foreach (var r in Model.Results)
                {
                    var pct = Model.MaxScore > 0 ? (int)(r.Score * 100 / Model.MaxScore) : 0;
                    <tr>
                        <td><a asp-controller="Students" asp-action="Details" asp-route-id="@r.StudentProfileId">@r.StudentProfile.Name</a></td>
                        <td><strong>@r.Score / @Model.MaxScore</strong></td>
                        <td><span class="badge @(pct >= 40 ? "bg-success" : "bg-danger")">@pct%</span></td>
                        <td><span class="badge bg-primary">@r.Grade</span></td>
                        <td class="text-end">
                            <a asp-controller="ExamResults" asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-controller="ExamResults" asp-action="Delete" asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div></div>
}

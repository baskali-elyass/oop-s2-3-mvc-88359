@model VgcCollege.Domain.AttendanceRecord
@{ ViewData["Title"] = "Record Attendance"; var enrolment = ViewBag.Enrolment as VgcCollege.Domain.CourseEnrolment; }
<h2>Record Attendance</h2>
@if (enrolment != null) { <p class="text-muted">@enrolment.StudentProfile.Name — @enrolment.Course.Name</p> }
<div class="card p-4" style="max-width:400px">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <input asp-for="CourseEnrolmentId" type="hidden" />
        <div class="mb-3"><label asp-for="WeekNumber" class="form-label"></label><input asp-for="WeekNumber" class="form-control" type="number" min="1" /><span asp-validation-for="WeekNumber" class="text-danger"></span></div>
        <div class="mb-3"><label asp-for="SessionDate" class="form-label"></label><input asp-for="SessionDate" class="form-control" type="date" /></div>
        <div class="mb-3 form-check"><input asp-for="Present" class="form-check-input" /><label asp-for="Present" class="form-check-label">Present</label></div>
        <div class="mb-3"><label asp-for="Notes" class="form-label"></label><input asp-for="Notes" class="form-control" /></div>
        <div class="d-flex gap-2"><button type="submit" class="btn btn-primary">Save</button><a asp-action="Index" asp-route-enrolmentId="@Model.CourseEnrolmentId" class="btn btn-outline-secondary">Cancel</a></div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }

@model VgcCollege.Domain.Assignment
@{ ViewData["Title"] = Model.Title; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>@Model.Title</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Back</a>
</div>
<div class="card p-3 mb-3" style="max-width:500px">
    <p class="mb-1"><strong>Course:</strong> <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId">@Model.Course.Name</a></p>
    <p class="mb-1"><strong>Max Score:</strong> @Model.MaxScore</p>
    <p class="mb-0"><strong>Due:</strong> @Model.DueDate.ToShortDateString()</p>
</div>
<div class="d-flex justify-content-between align-items-center mb-2">
    <h5>Results (@Model.Results.Count)</h5>
    <a asp-controller="AssignmentResults" asp-action="Create" asp-route-assignmentId="@Model.Id" class="btn btn-sm btn-primary">+ Add Result</a>
</div>
@if (!Model.Results.Any())
{ <div class="alert alert-info">No results entered yet.</div> }
else
{
    <div class="card"><div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Student</th><th>Score</th><th>%</th><th>Feedback</th><th></th></tr></thead>
            <tbody>
                @foreach (var r in Model.Results)
                {
                    var pct = Model.MaxScore > 0 ? (int)(r.Score * 100 / Model.MaxScore) : 0;
                    <tr>
                        <td><a asp-controller="Students" asp-action="Details" asp-route-id="@r.StudentProfileId">@r.StudentProfile.Name</a></td>
                        <td><strong>@r.Score / @Model.MaxScore</strong></td>
                        <td><span class="badge @(pct >= 40 ? "bg-success" : "bg-danger")">@pct%</span></td>
                        <td><small class="text-muted">@r.Feedback</small></td>
                        <td class="text-end">
                            <a asp-controller="AssignmentResults" asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-controller="AssignmentResults" asp-action="Delete" asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div></div>
}

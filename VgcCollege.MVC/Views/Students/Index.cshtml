@model IEnumerable<VgcCollege.Domain.StudentProfile>
@{ ViewData["Title"] = "Students"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Students</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">+ New Student</a>
    }
</div>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th><th>Student No.</th><th>Email</th><th>Phone</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.Name</td>
                        <td><code>@s.StudentNumber</code></td>
                        <td>@s.Email</td>
                        <td>@s.Phone</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary">View</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
                            {
                                <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-primary ms-1">Edit</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

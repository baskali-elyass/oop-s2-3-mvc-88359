@model VgcCollege.MVC.Models.FacultyDashboardViewModel
@{ ViewData["Title"] = "Faculty Dashboard"; }
<h2 class="mb-4">Welcome, @Model.FacultyName</h2>
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="fs-1">📚</div>
            <div class="fs-3 fw-bold">@Model.MyCourses.Count</div>
            <div class="text-muted small">My Courses</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center p-3">
            <div class="fs-1">👨‍🎓</div>
            <div class="fs-3 fw-bold">@Model.MyStudentCount</div>
            <div class="text-muted small">My Students</div>
        </div>
    </div>
</div>
<h5>My Courses</h5>
<div class="row g-3 mb-4">
    @foreach (var course in Model.MyCourses)
    {
        <div class="col-md-4">
            <div class="card p-3">
                <h6 class="fw-bold">@course.Name</h6>
                <small class="text-muted">@course.Branch.Name</small>
                <div class="mt-2 d-flex gap-2">
                    <a asp-controller="Assignments" asp-action="Index" asp-route-courseId="@course.Id" class="btn btn-sm btn-outline-primary">Assignments</a>
                    <a asp-controller="Exams" asp-action="Index" asp-route-courseId="@course.Id" class="btn btn-sm btn-outline-secondary">Exams</a>
                </div>
            </div>
        </div>
    }
</div>
<div class="d-flex gap-2">
    <a asp-controller="Students" asp-action="Index" class="btn btn-outline-primary">View My Students</a>
</div>

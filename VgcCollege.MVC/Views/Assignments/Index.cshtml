@model IEnumerable<VgcCollege.Domain.Assignment>
@{ ViewData["Title"] = "Assignments"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Assignments</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Assignment</a>
</div>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <select name="courseId" asp-items="ViewBag.Courses" class="form-select"><option value="">All Courses</option></select>
    </div>
    <div class="col-auto"><button type="submit" class="btn btn-outline-secondary">Filter</button></div>
</form>
<div class="card"><div class="card-body p-0">
    <table class="table table-hover mb-0">
        <thead class="table-light"><tr><th>Title</th><th>Course</th><th>Max Score</th><th>Due Date</th><th></th></tr></thead>
        <tbody>
            @foreach (var a in Model)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@a.Id">@a.Title</a></td>
                    <td><a asp-controller="Courses" asp-action="Details" asp-route-id="@a.CourseId">@a.Course.Name</a></td>
                    <td>@a.MaxScore</td>
                    <td>@a.DueDate.ToShortDateString()</td>
                    <td class="text-end">
                        <a asp-controller="AssignmentResults" asp-action="Index" asp-route-assignmentId="@a.Id" class="btn btn-sm btn-outline-info">Results</a>
                        <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary ms-1">Edit</a>
                        <a asp-action="Delete" asp-route-id="@a.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div></div>

@model VgcCollege.Domain.Course
@{ ViewData["Title"] = "Delete Course"; }
<h2>Delete Course</h2>
<div class="card p-4" style="max-width:500px">
    <div class="alert alert-danger">Are you sure you want to delete <strong>@Model.Name</strong>?</div>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2"><button type="submit" class="btn btn-danger">Delete</button><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></div>
    </form>
</div>

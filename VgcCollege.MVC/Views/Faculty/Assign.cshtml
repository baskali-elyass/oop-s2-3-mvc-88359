@model VgcCollege.Domain.FacultyCourseAssignment
@{ ViewData["Title"] = "Assign Course"; var faculty = ViewBag.Faculty as VgcCollege.Domain.FacultyProfile; }
<h2>Assign Course</h2>
@if (faculty != null) { <p class="text-muted">Assigning course to: <strong>@faculty.Name</strong></p> }
<div class="card p-4" style="max-width:500px">
    <form asp-action="Assign" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <input asp-for="FacultyProfileId" type="hidden" />
        <div class="mb-3"><label asp-for="CourseId" class="form-label">Course</label><select asp-for="CourseId" asp-items="ViewBag.Courses" class="form-select"><option value="">-- Select Course --</option></select></div>
        <div class="mb-3 form-check"><input asp-for="IsTutor" class="form-check-input" /><label asp-for="IsTutor" class="form-check-label">Is Personal Tutor for this course</label></div>
        <div class="d-flex gap-2"><button type="submit" class="btn btn-primary">Assign</button><a asp-action="Details" asp-route-id="@Model.FacultyProfileId" class="btn btn-outline-secondary">Cancel</a></div>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
